{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities (least privilege: core IPC + open external URLs)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-maximize",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }]
    }
  ]
}
